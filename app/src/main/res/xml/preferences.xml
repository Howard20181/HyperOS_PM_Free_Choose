<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">
    <ListPreference
        android:defaultValue="off"
        android:enabled="false"
        android:entries="@array/package_installer_unlock_entries"
        android:entryValues="@array/package_installer_unlock_values"
        android:key="package_installer_unlock"
        android:shouldDisableView="true"
        android:summary="@string/package_installer_unlock_summary"
        android:title="@string/package_installer_unlock_title" />
    <EditTextPreference
        android:defaultValue=""
        android:dialogTitle="@string/package_installer_custom_package_name_title"
        android:enabled="false"
        android:inputType="text"
        android:key="package_installer_custom_package_name"
        android:shouldDisableView="true"
        android:title="@string/package_installer_custom_package_name_title" />

</PreferenceScreen>
